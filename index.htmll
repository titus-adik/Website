<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scire Research – Foundation for Africa's Data-Driven Future</title>
    <meta name="description"
        content="Scire Research is building the foundation for Africa's data-driven future — verified data infrastructure, AI-powered intelligence, and global research partnerships from Kenya.">

    <link rel="icon" type="image/svg+xml"
        href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Cline x1='62' y1='62' x2='82' y2='82' stroke='%23e67e22' stroke-width='6' stroke-linecap='round'/%3E%3Ccircle cx='45' cy='45' r='28' fill='none' stroke='%231a5276' stroke-width='5'/%3E%3Cpath d='M35,25 Q45,35 35,45 Q25,55 35,65' fill='none' stroke='%23e67e22' stroke-width='2.5' stroke-linecap='round'/%3E%3Cpath d='M55,25 Q45,35 55,45 Q65,55 55,65' fill='none' stroke='%23148f8f' stroke-width='2.5' stroke-linecap='round'/%3E%3Ccircle cx='45' cy='45' r='3' fill='%23e67e22'/%3E%3C/svg%3E">

    <style>
        /* ===== RESET & BASE ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #1e2a3a;
            line-height: 1.6;
            background: #fafbfc;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        h1,
        h2,
        h3,
        h4 {
            font-weight: 700;
            line-height: 1.2;
        }

        a {
            color: #1e3c72;
            text-decoration: none;
            transition: color 0.2s;
        }

        a:hover {
            color: #4a7ab5;
        }

        /* ===== BUTTONS ===== */
        .btn {
            display: inline-block;
            background: #1e3c72;
            color: #fff;
            padding: 12px 30px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 1rem;
            border: none;
            cursor: pointer;
            transition: background 0.3s, transform 0.2s;
            text-align: center;
        }

        .btn:hover {
            background: #2a5298;
            transform: translateY(-2px);
        }

        .btn-small {
            padding: 6px 18px;
            font-size: 0.8rem;
            background: transparent;
            color: #fff;
            border: 2px solid rgba(255, 255, 255, 0.5);
            border-radius: 30px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            text-align: center;
        }

        .btn-small:hover {
            background: #fff;
            color: #1e3c72;
            border-color: #fff;
            transform: translateY(-2px);
        }

        .section-title {
            text-align: center;
            font-size: 2.2rem;
            margin-bottom: 12px;
            color: #0b1e33;
        }

        .section-subtitle {
            text-align: center;
            font-size: 1.1rem;
            color: #4a5b6e;
            max-width: 650px;
            margin: 0 auto 50px;
        }

        /* ===== HEADER - ENCLOSED ===== */
        header {
            position: absolute;
            top: 20px;
            left: 0;
            width: 100%;
            z-index: 100;
            padding: 0;
        }

        header .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .header-enclosed {
            background: rgba(11, 30, 51, 0.7);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 50px;
            padding: 10px 25px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
            transition: all 0.3s ease;
        }

        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
        }

        /* ===== LOGO ===== */
        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }

        .logo svg {
            height: 35px;
            width: auto;
            flex-shrink: 0;
        }

        .logo-text {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .logo-text .main {
            font-size: 1.3rem;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.5px;
            white-space: nowrap;
        }

        .logo-text .main span {
            color: #7aafd4;
        }

        .logo-text .tagline {
            font-size: 0.5rem;
            font-weight: 400;
            color: rgba(255, 255, 255, 0.8);
            letter-spacing: 0.5px;
            text-transform: uppercase;
            white-space: nowrap;
        }

        /* ===== DESKTOP NAV ===== */
        .desktop-nav {
            display: flex;
            align-items: center;
            gap: 15px;
            flex-wrap: wrap;
        }

        .desktop-nav a {
            font-weight: 500;
            color: rgba(255, 255, 255, 0.85);
            font-size: 0.85rem;
            transition: color 0.2s;
            white-space: nowrap;
        }

        .desktop-nav a:hover {
            color: #fff;
        }

        /* ===== SCROLLED STATE ===== */
        header.scrolled .header-enclosed {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid #eaeef3;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        }

        header.scrolled .logo-text .main {
            color: #1e3c72;
        }

        header.scrolled .logo-text .main span {
            color: #4a7ab5;
        }

        header.scrolled .logo-text .tagline {
            color: #4a5b6e;
        }

        header.scrolled .desktop-nav a {
            color: #2c3e50;
        }

        header.scrolled .desktop-nav a:hover {
            color: #1e3c72;
        }

        header.scrolled .desktop-nav .btn-small {
            color: #1e3c72;
            border: 2px solid #1e3c72;
        }

        header.scrolled .desktop-nav .btn-small:hover {
            background: #1e3c72;
            color: #fff;
        }

        header.scrolled .hamburger .bar {
            background: #1e3c72;
        }

        /* ===== HAMBURGER ===== */
        .hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            padding: 5px;
            z-index: 101;
        }

        .hamburger .bar {
            display: block;
            width: 28px;
            height: 3px;
            background: #fff;
            border-radius: 3px;
            transition: all 0.3s ease;
        }

        .hamburger.active .bar:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }

        .hamburger.active .bar:nth-child(2) {
            opacity: 0;
        }

        .hamburger.active .bar:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
        }

        /* ===== MOBILE MENU ===== */
        .mobile-menu-overlay {
            position: fixed;
            top: 0;
            right: -100%;
            width: 80%;
            max-width: 350px;
            height: 100%;
            background: #1e3c72;
            z-index: 1000;
            transition: right 0.4s ease;
            padding: 60px 30px;
            box-shadow: -10px 0 30px rgba(0, 0, 0, 0.2);
            overflow-y: auto;
        }

        .mobile-menu-overlay.open {
            right: 0;
        }

        .mobile-menu-close {
            position: absolute;
            top: 20px;
            right: 20px;
            font-size: 2rem;
            color: #fff;
            cursor: pointer;
            opacity: 0.8;
            transition: opacity 0.3s;
        }

        .mobile-menu-close:hover {
            opacity: 1;
        }

        .mobile-nav {
            display: flex;
            flex-direction: column;
            gap: 25px;
            margin-top: 40px;
        }

        .mobile-nav a {
            color: #fff;
            font-size: 1.3rem;
            font-weight: 500;
            text-decoration: none;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            transition: color 0.3s;
        }

        .mobile-nav a:hover {
            color: #4a7ab5;
        }

        .mobile-nav .btn {
            display: inline-block;
            margin-top: 10px;
            text-align: center;
            background: #fff;
            color: #1e3c72;
            padding: 12px 30px;
            border-radius: 30px;
            font-weight: 600;
        }

        .mobile-nav .btn:hover {
            background: #eaeef3;
        }

        @media (max-width: 768px) {
            .desktop-nav {
                display: none;
            }

            .hamburger {
                display: flex;
            }

            .header-enclosed {
                padding: 8px 16px;
                border-radius: 30px;
            }

            .logo-text .main {
                font-size: 1rem;
            }

            .logo-text .tagline {
                font-size: 0.4rem;
            }

            .logo svg {
                height: 28px;
            }
        }

        @media (min-width: 769px) {
            .hamburger {
                display: none;
            }

            .mobile-menu-overlay {
                display: none;
            }
        }

        /* ===== HERO ===== */
        .hero {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background: #0b1e33;
        }

        .bg-video {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: 0;
            filter: brightness(1.3) contrast(1.1);
        }

        .bg-video source+img {
            display: none;
        }

        .hero .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.35);
            z-index: 1;
            pointer-events: none;
        }

        .hero .container {
            position: relative;
            z-index: 2;
            text-align: center;
            color: #fff;
            padding: 20px;
            max-width: 900px;
        }

        .hero-slider {
            position: relative;
            min-height: 300px;
        }

        .hero-slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            opacity: 0;
            transition: opacity 0.8s ease-in-out, transform 0.8s ease-in-out;
            transform: translateY(20px);
            pointer-events: none;
            visibility: hidden;
        }

        .hero-slide.active {
            opacity: 1;
            transform: translateY(0);
            pointer-events: auto;
            visibility: visible;
            position: relative;
        }

        .hero-slide h1 {
            font-size: 2.8rem;
            margin-bottom: 16px;
            color: #fff;
            text-shadow: 0 2px 20px rgba(0, 0, 0, 0.6);
        }

        .hero-slide .highlight {
            border-bottom: 4px solid #4a7ab5;
        }

        .hero-slide p {
            font-size: 1.2rem;
            color: #e8edf5;
            max-width: 700px;
            margin: 0 auto 30px;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
        }

        .hero-slide .btn-group {
            display: flex;
            justify-content: center;
            gap: 15px;
            flex-wrap: wrap;
        }

        .trust-badge {
            display: flex;
            justify-content: center;
            gap: 20px 30px;
            flex-wrap: wrap;
            font-size: 0.9rem;
            color: #b0c4de;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 30px;
            margin-top: 40px;
            align-items: center;
        }

        .trust-badge span {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-shadow: 0 1px 8px rgba(0, 0, 0, 0.4);
            white-space: nowrap;
        }

        .slider-dots {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin-top: 30px;
        }

        .slider-dots .dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            cursor: pointer;
            transition: background 0.3s, transform 0.3s;
            display: inline-block;
        }

        .slider-dots .dot:hover {
            background: rgba(255, 255, 255, 0.6);
            transform: scale(1.2);
        }

        .slider-dots .dot.active {
            background: #4a7ab5;
            transform: scale(1.3);
        }

        @media (max-width: 768px) {
            .hero-slide h1 {
                font-size: 2rem;
            }

            .hero-slide p {
                font-size: 1rem;
            }

            .hero-slider {
                min-height: 350px;
            }

            .trust-badge span {
                white-space: normal;
            }
        }

        @media (max-width: 480px) {
            .hero-slide h1 {
                font-size: 1.6rem;
            }

            .hero-slide .btn-group {
                flex-direction: column;
                align-items: center;
            }

            .hero-slider {
                min-height: 400px;
            }

            .trust-badge {
                gap: 10px 15px;
                font-size: 0.75rem;
            }
        }

        /* ===== SECTIONS ===== */
        section {
            padding: 60px 0;
        }

        .section-alt {
            background: #f4f7fa;
        }

        /* ===== SERVICES - SHORTENED ===== */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 25px;
            max-width: 900px;
            margin: 0 auto;
        }

        .service-item {
            background: #fff;
            padding: 25px 15px;
            border-radius: 12px;
            text-align: center;
            border: 1px solid #eaeef3;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        }

        .service-item:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
        }

        .service-item .icon {
            font-size: 2.2rem;
            margin-bottom: 8px;
        }

        .service-item h4 {
            font-size: 0.95rem;
            color: #1e3c72;
            margin-bottom: 4px;
        }

        .service-item p {
            font-size: 0.8rem;
            color: #4a5b6e;
            line-height: 1.4;
        }

        @media (max-width: 768px) {
            .services-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 15px;
            }
        }

        @media (max-width: 480px) {
            .services-grid {
                grid-template-columns: 1fr;
                max-width: 100%;
            }
        }

        /* ===== WHO WE SERVE - SHORTENED ===== */
        .serve-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            max-width: 900px;
            margin: 0 auto;
        }

        .serve-item {
            background: #fff;
            padding: 20px 16px;
            border-radius: 12px;
            text-align: center;
            border-left: 3px solid #1e3c72;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        }

        .serve-item h4 {
            font-size: 0.95rem;
            color: #1e3c72;
            margin-bottom: 4px;
        }

        .serve-item p {
            font-size: 0.8rem;
            color: #4a5b6e;
            line-height: 1.4;
        }

        @media (max-width: 1024px) {
            .serve-grid {
                grid-template-columns: repeat(2, 1fr);
                max-width: 600px;
            }
        }

        @media (max-width: 480px) {
            .serve-grid {
                grid-template-columns: 1fr;
                max-width: 100%;
            }
        }

        /* ===== STATS ===== */
        .stats {
            background: #1e3c72;
            color: #fff;
            padding: 40px 0;
            text-align: center;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 30px;
            max-width: 900px;
            margin: 0 auto;
        }

        .stats-grid .stat-number {
            font-size: 2rem;
            font-weight: 800;
            display: block;
        }

        .stats-grid .stat-label {
            font-size: 0.85rem;
            opacity: 0.85;
        }

        @media (max-width: 768px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 20px;
            }
        }

        @media (max-width: 480px) {
            .stats-grid {
                grid-template-columns: 1fr;
                gap: 15px;
            }
        }

        /* ===== PRODUCTS ===== */
        #products {
            position: relative;
            color: #fff;
            padding: 60px 0;
            overflow: hidden;
            min-height: 400px;
            display: flex;
            align-items: center;
        }

        #products .bg-video {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: 0;
            filter: brightness(1.1) contrast(1.05);
        }

        #products .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.55);
            z-index: 1;
        }

        #products .content {
            position: relative;
            z-index: 2;
            text-align: center;
        }

        .vision-pillars {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;
            margin: 30px 0;
        }

        .vision-pillars .pillar {
            background: rgba(255, 255, 255, 0.08);
            padding: 15px 20px;
            border-radius: 12px;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            min-width: 140px;
            text-align: center;
        }

        .vision-pillars .pillar .icon {
            font-size: 2rem;
            display: block;
            margin-bottom: 4px;
        }

        .vision-pillars .pillar span {
            font-size: 0.85rem;
            color: #d0ddea;
            font-weight: 500;
        }

        @media (max-width: 768px) {
            #products {
                padding: 40px 0;
                min-height: 300px;
            }

            #products h2 {
                font-size: 1.8rem !important;
            }

            .vision-pillars .pillar {
                min-width: 100px;
                padding: 12px 15px;
            }
        }

        /* ===== WHY CHOOSE US - SHORTENED ===== */
        .why-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            max-width: 900px;
            margin: 0 auto;
        }

        .why-card {
            background: #fff;
            padding: 25px 18px;
            border-radius: 12px;
            text-align: center;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
            border-bottom: 3px solid #1e3c72;
            transition: transform 0.2s;
        }

        .why-card:hover {
            transform: translateY(-4px);
        }

        .why-card .icon {
            font-size: 2.2rem;
            display: block;
            margin-bottom: 8px;
        }

        .why-card h4 {
            font-size: 0.95rem;
            color: #1e3c72;
            margin-bottom: 4px;
        }

        .why-card p {
            font-size: 0.8rem;
            color: #4a5b6e;
            line-height: 1.4;
        }

        .why-card.featured {
            background: linear-gradient(135deg, #0b1e33, #1e3c72);
            border-bottom-color: #7aafd4;
        }

        .why-card.featured h4 {
            color: #fff;
        }

        .why-card.featured p {
            color: #b0c4de;
        }

        @media (max-width: 1024px) {
            .why-grid {
                grid-template-columns: repeat(2, 1fr);
                max-width: 600px;
            }
        }

        @media (max-width: 480px) {
            .why-grid {
                grid-template-columns: 1fr;
                max-width: 100%;
            }
        }

        /* ===== TESTIMONIALS ===== */
        .testimonial-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 30px;
            max-width: 800px;
            margin: 0 auto;
        }

        .testimonial-item {
            background: #fff;
            padding: 25px;
            border-radius: 12px;
            border: 1px solid #eaeef3;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        }

        .testimonial-item .quote {
            font-style: italic;
            color: #1e2a3a;
            font-size: 0.95rem;
            margin-bottom: 10px;
        }

        .testimonial-item .author {
            font-weight: 600;
            color: #1e3c72;
            font-size: 0.9rem;
        }

        .testimonial-item .source {
            font-size: 0.8rem;
            color: #4a5b6e;
        }

        @media (max-width: 768px) {
            .testimonial-grid {
                grid-template-columns: 1fr;
                max-width: 100%;
            }
        }

        /* ===== BLOG - SHORTENED ===== */
        .blog-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 25px;
            max-width: 800px;
            margin: 0 auto;
        }

        .blog-card {
            background: #fff;
            padding: 25px 20px;
            border-radius: 12px;
            border: 1px solid #eaeef3;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
            transition: transform 0.2s;
        }

        .blog-card:hover {
            transform: translateY(-4px);
        }

        .blog-card h3 {
            font-size: 1.05rem;
            color: #1e3c72;
            margin-bottom: 6px;
        }

        .blog-card p {
            color: #4a5b6e;
            font-size: 0.85rem;
            line-height: 1.5;
            margin-bottom: 10px;
        }

        .blog-card .read-more {
            display: inline-block;
            color: #4a7ab5;
            font-weight: 600;
            font-size: 0.85rem;
        }

        .blog-card .read-more:hover {
            color: #1e3c72;
        }

        @media (max-width: 768px) {
            .blog-grid {
                grid-template-columns: 1fr;
                max-width: 100%;
            }
        }

        /* ===== FAQ - SHORTENED ===== */
        .faq-grid {
            max-width: 700px;
            margin: 0 auto;
        }

        .faq-item {
            background: #fff;
            padding: 14px 20px;
            border-radius: 8px;
            margin-bottom: 10px;
            border: 1px solid #eaeef3;
            cursor: pointer;
            transition: border-color 0.2s;
        }

        .faq-item:hover {
            border-color: #1e3c72;
        }

        .faq-item h4 {
            font-size: 0.95rem;
            margin-bottom: 2px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .faq-item h4 .toggle {
            font-size: 1.1rem;
            color: #4a7ab5;
        }

        .faq-item p {
            font-size: 0.85rem;
            color: #3d4e62;
            display: none;
            margin-top: 6px;
            line-height: 1.5;
        }

        .faq-item.active p {
            display: block;
        }

        .faq-more {
            text-align: center;
            margin-top: 20px;
        }

        .faq-more a {
            color: #4a7ab5;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .faq-more a:hover {
            color: #1e3c72;
        }

        /* ===== CONTACT ===== */
        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            max-width: 900px;
            margin: 0 auto;
        }

        .contact-info-box {
            background: #fff;
            padding: 25px;
            border-radius: 12px;
            border: 1px solid #eaeef3;
        }

        .contact-info-box h3 {
            margin-bottom: 12px;
            font-size: 1.2rem;
            color: #0b1e33;
        }

        .contact-info-box .detail {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }

        .contact-info-box .detail .icon {
            font-size: 1.2rem;
        }

        .contact-form-box {
            background: #fff;
            padding: 25px;
            border-radius: 12px;
            border: 1px solid #eaeef3;
        }

        .contact-form-box h3 {
            margin-bottom: 12px;
            font-size: 1.2rem;
            color: #0b1e33;
        }

        .form-group {
            margin-bottom: 12px;
        }

        .form-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 4px;
            font-size: 0.85rem;
        }

        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 8px 12px;
            border: 1px solid #d0d7de;
            border-radius: 8px;
            font-family: inherit;
            font-size: 0.95rem;
            transition: border-color 0.2s;
        }

        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            outline: none;
            border-color: #1e3c72;
        }

        .form-group textarea {
            resize: vertical;
            min-height: 100px;
        }

        .form-status {
            margin-top: 12px;
            padding: 10px;
            border-radius: 8px;
            display: none;
        }

        .form-status.success {
            display: block;
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .form-status.error {
            display: block;
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        @media (max-width: 768px) {
            .contact-grid {
                grid-template-columns: 1fr;
                gap: 25px;
                max-width: 100%;
            }
        }

        /* ===== CTA ===== */
        .cta {
            background: linear-gradient(135deg, #0b1e33, #1e3c72);
            color: #fff;
            text-align: center;
            padding: 50px 0;
        }

        .cta h2 {
            font-size: 2rem;
        }

        .cta p {
            font-size: 1.05rem;
            margin: 10px 0 25px;
            opacity: 0.9;
        }

        .cta .btn {
            background: #fff;
            color: #1e3c72;
        }

        .cta .btn:hover {
            background: #eaeef3;
        }

        .cta .contact-info {
            margin-top: 15px;
            display: flex;
            justify-content: center;
            gap: 25px;
            flex-wrap: wrap;
            font-size: 0.9rem;
        }

        .cta .contact-info a {
            color: #b0c4de;
        }

        .cta .contact-info a:hover {
            color: #fff;
        }

        @media (max-width: 768px) {
            .cta h2 {
                font-size: 1.6rem;
            }

            .cta .contact-info {
                flex-direction: column;
                gap: 8px;
            }
        }

        /* ===== FOOTER ===== */
        footer {
            background: #0b1e33;
            color: #b0c4de;
            text-align: center;
            padding: 25px 0;
            font-size: 0.85rem;
        }

        footer a {
            color: #b0c4de;
        }

        footer a:hover {
            color: #fff;
        }

        footer .footer-links {
            margin-top: 8px;
            display: flex;
            justify-content: center;
            gap: 18px;
            flex-wrap: wrap;
        }

        .social-links a {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            transition: background 0.3s, transform 0.2s;
        }

        .social-links a:hover {
            background: #4a7ab5;
            transform: translateY(-3px);
        }

        .social-links svg {
            width: 18px;
            height: 18px;
        }
    </style>
</head>

